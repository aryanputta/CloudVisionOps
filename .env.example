# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# Stack names
STACK_PREFIX=CloudVisionOps
ENVIRONMENT=dev

# DynamoDB Tables (set by CDK output)
IMAGE_METADATA_TABLE=CloudVisionOps-ImageMetadata-dev
OPS_RECOMMENDATIONS_TABLE=CloudVisionOps-OpsRecommendations-dev

# S3 Buckets (set by CDK output)
IMAGE_UPLOAD_BUCKET=cloudvisionops-uploads-dev-123456789012

# SQS (set by CDK output)
DLQ_URL=https://sqs.us-east-1.amazonaws.com/123456789012/CloudVisionOps-DLQ-dev

# API Gateway (set by CDK output)
API_BASE_URL=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com/dev

# Cognito (set by CDK output after deploy)
# VITE_COGNITO_DOMAIN=https://cloudvisionops-dev.auth.us-east-1.amazoncognito.com
# VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
# Leave blank in dev to bypass auth gate entirely

# Agentic ops — store in SSM, not here
# aws ssm put-parameter --name /cloudvisionops/anthropic-api-key --type SecureString --value sk-ant-...
# ANTHROPIC_API_KEY=sk-ant-...

# Rekognition
REKOGNITION_MAX_LABELS=20
REKOGNITION_MIN_CONFIDENCE=70

# Lambda tuning
PROCESSOR_LAMBDA_MEMORY=1024
UPLOAD_HANDLER_MEMORY=256
OPS_AGENT_MEMORY=512

# Duplicate detection
ENABLE_DUPLICATE_DETECTION=true

# Cost tracking
REKOGNITION_PRICE_PER_IMAGE=0.001
LAMBDA_PRICE_PER_GB_SECOND=0.0000166667
