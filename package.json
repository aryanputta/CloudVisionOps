{
  "name": "cloudvisionops",
  "version": "1.0.0",
  "description": "Serverless AI image intelligence pipeline on AWS",
  "private": true,
  "workspaces": [
    "frontend",
    "infra/cdk"
  ],
  "scripts": {
    "bootstrap": "npm install && cd infra/cdk && npm install && cd ../../frontend && npm install",
    "synth": "cd infra/cdk && npx cdk synth",
    "diff": "cd infra/cdk && npx cdk diff",
    "deploy": "cd infra/cdk && npx cdk deploy --all --require-approval never",
    "destroy": "cd infra/cdk && npx cdk destroy --all",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "cd tests && npx jest unit/",
    "test:reliability": "cd tests && npx jest reliability/",
    "lint": "eslint 'backend/**/*.ts' 'infra/**/*.ts' --ext .ts",
    "build:lambdas": "cd backend && npm run build",
    "benchmark": "python3 benchmarks/upload_benchmark.py",
    "benchmark:local": "python3 benchmarks/upload_benchmark.py --simulate --batch 100 --include-duplicates"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "@aws-sdk/client-dynamodb": "^3.600.0",
    "@aws-sdk/lib-dynamodb": "^3.600.0",
    "@aws-sdk/util-dynamodb": "^3.600.0",
    "@aws-sdk/client-rekognition": "^3.600.0",
    "@aws-sdk/client-sns": "^3.600.0",
    "@aws-sdk/client-sqs": "^3.600.0",
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@types/aws-lambda": "^8.10.140",
    "uuid": "^9.0.1",
    "@types/uuid": "^9.0.8",
    "ts-node": "^10.9.2"
  }
}
